generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"  
  url      = env("DATABASE_URL")  // Using environment variable for the DB URL
}

enum Role {
  PARENT
  TEACHER
}

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(PARENT)
  name         String?
  birthdate    DateTime?

  children     Child[]
  messages     Message[]
  createdAt    DateTime @default(now())
}

model Child {
  id                    String    @id @default(cuid())
  displayName           String
  birthdate             DateTime?
  coins                 Int       @default(0)
  childCode             String    @unique

  // ERD fields
  email                 String?
  passwordHash          String?
  generalLevel          Int       @default(1)
  subjectsOfInterest    String?   // JSON array e.g. '["Math","Reading"]'
  mentalHealthConditions String?  // free-text or JSON notes
  avatarConfig          String?   // JSON object for avatar customisation

  // Presence — set by the game's POST /heartbeat. Use staleness vs lastSeenAt to derive online status.
  lastSeenAt            DateTime?
  currentSubjectId      String?

  // Parent-controlled force stop. When true, the game shows its blocked overlay
  // and bypasses any local dev "force allow play" toggle.
  forceStopped          Boolean  @default(false)
  forceStoppedAt        DateTime?

  // AI in-game help — after X mistakes the game asks the backend (OpenAI) for a kid-friendly hint.
  aiHelpEnabled         Boolean  @default(true)
  aiHelpThreshold       Int      @default(3)        // X — number of mistakes that triggers a hint
  aiHelpMode            String   @default("streak") // "streak" = wrong in a row | "total" = wrong per play session

  parentId      String
  parent        Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  subjects      SubjectProgress[]
  rewards       Reward[]
  timeControls  TimeControls?
  messages      Message[]
  sessions      Session[]
  answers       AnswerRecord[]
  scores        ScoreRecord[]
  aiHelpEvents  AiHelpEvent[]

  createdAt     DateTime @default(now())
}


model Subject {
  id          String   @id @default(cuid())
  name        String
  description String?

  progress    SubjectProgress[]
  sessions    Session[]
  answers     AnswerRecord[]
  scores      ScoreRecord[]
}

model SubjectProgress {
  id           String   @id @default(cuid())

  childId      String
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  timeSpentSec    Int      @default(0)
  completion      Float    @default(0)
  lastPlayedAt    DateTime?
  keyPresses      String?  // JSON array of timestamped key-press events

  @@unique([childId, subjectId])
}

model Reward {
  id          String   @id @default(cuid())
  type        String
  value       Int
  name        String?
  description String?

  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model TimeControls {
  id                 String   @id @default(cuid())
  dailyMinutes       Int      @default(60)
  sessionMinutes     Int      @default(25)
  breakMinutes       Int      @default(7)
  allowedFrom        String?  // "16:00"
  allowedTo          String?  // "18:00"
  bedtimeBlock       String?  // "20:30" — time after which access is blocked
  blockAfterBedtime  Boolean  @default(true)
  maxSessionsAllowed Int?

  childId   String   @unique
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  content   String
  read      Boolean  @default(false)

  parentId  String
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Session {
  id          String   @id @default(cuid())

  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  durationSec Int      @default(0)
  completion  Float?

  startedAt   DateTime?
  endedAt     DateTime @default(now())

  @@index([childId])
  @@index([childId, endedAt])
}

model AnswerRecord {
  id            String   @id @default(cuid())

  childId       String
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  subjectId     String?
  subject       Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  question      String?   @db.Text
  options       Json?     // The choices shown to the kid, as a JSON array of strings
  userAnswer    String?   @db.Text
  correctAnswer String?   @db.Text
  isCorrect     Boolean
  timedOut      Boolean   @default(false)  // true → kid ran out of time before answering

  createdAt     DateTime @default(now())

  @@index([childId, createdAt])
  @@index([childId, subjectId, createdAt])
}

/// Anonymous site analytics. No raw IP, no cookies, no PII.
/// Each row is one page view. durationMs grows via /heartbeat.
model PageView {
  id         String   @id @default(cuid())

  sessionId  String   @db.VarChar(64)    // anonymous client-generated UUID (sessionStorage)
  path       String   @db.VarChar(500)   // VARCHAR (not TEXT) so MySQL can index it
  referrer   String?  @db.VarChar(500)

  // Coarse IP-derived geo. Fetched by the client from ipapi.co — we
  // never store lat/lng. Server stores whatever the client sent.
  country    String?  @db.VarChar(8)
  region     String?  @db.VarChar(96)
  city       String?  @db.VarChar(96)
  org        String?  @db.VarChar(128)   // ISP / network name

  // Family-level UA only — no exact versions to prevent fingerprinting
  browser    String?  @db.VarChar(32)
  os         String?  @db.VarChar(32)
  device     String?  @db.VarChar(16)    // "desktop" | "mobile" | "tablet"

  // SHA-256(clientIP + server salt), truncated. One-way; for rough unique counts.
  ipHash     String   @db.VarChar(64)

  // True if a logged-in parent triggered the view
  isParent   Boolean  @default(false)

  // Identity of the logged-in parent at the time of the visit (best-effort).
  // Decoded server-side from the Authorization header — never client-supplied.
  parentId    String?  @db.VarChar(64)
  parentEmail String?  @db.VarChar(200)

  // Time on page, updated by /heartbeat (clamped to a sane upper bound)
  durationMs Int      @default(0)

  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
  @@index([country])
  @@index([path])
}

model ScoreRecord {
  id        String   @id @default(cuid())

  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  score     Int
  maxScore  Int?
  label     String?   // free-text — e.g. "Level 3", "Speed quiz", "Final boss"

  createdAt DateTime @default(now())

  @@index([childId, createdAt])
  @@index([childId, subjectId, createdAt])
}

/// One row per time the game triggered AI help after the child hit the mistake
/// threshold. Stores the question + wrong answer that prompted it and the hint
/// the AI generated, so the parent can review what their child was shown.
model AiHelpEvent {
  id            String   @id @default(cuid())

  childId       String
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  subjectId     String?
  question      String?  @db.Text
  userAnswer    String?  @db.Text
  correctAnswer String?  @db.Text
  options       Json?
  mode          String?  // "streak" | "total" — which counter tripped
  triggerCount  Int?     // the streak/total value at trigger time
  hint          String   @db.Text

  createdAt     DateTime @default(now())

  @@index([childId, createdAt])
}
